<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Undo：左弯箭头 -->
  <StreamGeometry x:Key="IconCommandUndo">M4 4 L0 8 L4 12 M0 8 L10 8 C13 8 15 10 15 13 L15 15</StreamGeometry>
  <!-- Redo：右弯箭头 -->
  <StreamGeometry x:Key="IconCommandRedo">M12 4 L16 8 L12 12 M16 8 L6 8 C3 8 1 10 1 13 L1 15</StreamGeometry>
  <!-- Save：磁盘 -->
  <StreamGeometry x:Key="IconCommandSave">M2 1 L2 15 L14 15 L14 5 L11 1 L5 1 M5 1 L5 7 L11 7 L11 1 M5 10 C5 8.3 6.8 7 9 7 C11.2 7 13 8.3 13 10 C13 11.7 11.2 13 9 13 C6.8 13 5 11.7 5 10 Z</StreamGeometry>
  <!-- ResetLayout：回转箭头恢复 -->
  <StreamGeometry x:Key="IconCommandResetLayout">M8 2 C4.7 2 2 4.7 2 8 M2 8 L2 4 M2 8 L6 8 M8 14 C11.3 14 14 11.3 14 8 M14 8 L14 12 M14 8 L10 8 M4 11 L12 11 L12 13 L4 13 Z</StreamGeometry>
</ResourceDictionary>
