<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Undo：左弯箭头 -->
  <StreamGeometry x:Key="IconCommandUndo">M3 5 L0 8 L3 11 M0 8 L9 8 C12 8 14 10 14 13</StreamGeometry>
  <!-- Redo：右弯箭头 -->
  <StreamGeometry x:Key="IconCommandRedo">M13 5 L16 8 L13 11 M16 8 L7 8 C4 8 2 10 2 13</StreamGeometry>
  <!-- Save：软盘 -->
  <StreamGeometry x:Key="IconCommandSave">M3 1 L13 1 L15 3 L15 15 L3 15 Z M5 1 L5 6 L11 6 L11 1 M5 10 L13 10 L13 13 L5 13 Z</StreamGeometry>
  <!-- ResetLayout：窗口布局 + 重置箭头 -->
  <StreamGeometry x:Key="IconCommandResetLayout">M2 5 L14 5 L14 14 L2 14 Z M2 5 L14 5 M5 5 L5 14 M13 3 C15 4 15 7 13 8 M13 8 L11 7 M13 8 L15 7</StreamGeometry>
</ResourceDictionary>
