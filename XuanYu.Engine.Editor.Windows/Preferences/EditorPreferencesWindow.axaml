<Window
    x:Class="XuanYu.Engine.Editor.Windows.Preferences.EditorPreferencesWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="偏好设置"
    Width="720"
    Height="520"
    MinWidth="600"
    MinHeight="400"
    WindowStartupLocation="CenterOwner"
    Background="#202327"
    Foreground="#E0E0E0"
    Opened="OnOpened"
    KeyDown="OnWindowKeyDown"
    PointerPressed="OnWindowPointerPressed"
    PointerWheelChanged="OnWindowPointerWheelChanged">
  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Row 0: 标题 / 搜索 / 预设 -->
    <Border Grid.Row="0" Background="#2A2F36" Padding="12,8" BorderBrush="#414852" BorderThickness="0,0,0,1">
      <StackPanel Spacing="8">
        <TextBlock Text="键位设置" FontSize="18" FontWeight="Bold" Foreground="#FFF" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBox x:Name="SearchBox" PlaceholderText="搜索动作或按键…" Width="280" Height="30"
                   TextChanged="OnSearchTextChanged" />
          <TextBlock Text="预设：" VerticalAlignment="Center" Foreground="#AAA" />
          <ComboBox x:Name="PresetCombo" SelectedIndex="0" Width="140" IsEnabled="False">
            <ComboBoxItem>Blender 默认</ComboBoxItem>
          </ComboBox>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Row 1: 可滚动绑定列表 -->
    <ScrollViewer Grid.Row="1" Margin="8,4">
      <StackPanel x:Name="BindingsContainer" Spacing="1" />
    </ScrollViewer>

    <!-- Row 2: 固定底部操作栏 -->
    <Border Grid.Row="2" Background="#2A2F36" Padding="12,8" BorderBrush="#414852" BorderThickness="0,1,0,0">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button x:Name="RestoreAllButton" Content="恢复全部默认"
                Background="#3A3F48" Foreground="#CCC" BorderThickness="1" BorderBrush="#555"
                Padding="10,5" Click="OnRestoreAllClicked" />
        <Button Content="取消" Background="#3A3F48" Foreground="#CCC"
                BorderThickness="1" BorderBrush="#555" Padding="10,5" Click="OnCancelClicked" />
        <Button x:Name="ApplyButton" Content="应用" IsEnabled="False"
                Background="#3A3F48" Foreground="#CCC" BorderThickness="1" BorderBrush="#555"
                Padding="10,5" Click="OnApplyClicked" />
        <Button x:Name="SaveButton" Content="保存" IsEnabled="False"
                Background="#4A7FEF" Foreground="#FFF" BorderThickness="0"
                Padding="12,5" FontWeight="Bold" Click="OnSaveClicked" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
