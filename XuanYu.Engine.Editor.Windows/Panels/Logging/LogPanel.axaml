<UserControl
    x:Class="XuanYu.Engine.Editor.Windows.Panels.Logging.LogPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Padding="10,8"
      Background="#1B2026"
      BorderBrush="#48515C"
      BorderThickness="0,1,0,0">
    <TextBox
        x:Name="LogTextBox"
        AcceptsReturn="True"
        Background="#11161C"
        BorderBrush="#303944"
        BorderThickness="1"
        CaretBrush="#F0F4F8"
        FontFamily="Consolas, Microsoft YaHei UI"
        FontSize="12"
        Foreground="#DCE3EA"
        IsReadOnly="True"
        Padding="8"
        ScrollViewer.HorizontalScrollBarVisibility="Auto"
        ScrollViewer.VerticalScrollBarVisibility="Auto"
        TextWrapping="NoWrap" />
  </Border>
</UserControl>
