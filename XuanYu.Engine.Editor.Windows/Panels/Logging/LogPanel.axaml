<UserControl
    x:Class="XuanYu.Engine.Editor.Windows.Panels.Logging.LogPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Padding="10,8"
      Background="{StaticResource BrushEditorBottomDockBackground}"
      BorderBrush="{StaticResource BrushEditorBorder}"
      BorderThickness="0,1,0,0">
    <TextBox
        x:Name="LogTextBox"
        AcceptsReturn="True"
        Background="{StaticResource BrushEditorInputBackground}"
        BorderBrush="{StaticResource BrushEditorBorderSoft}"
        BorderThickness="1"
        FontFamily="Consolas, Microsoft YaHei UI"
        FontSize="12"
        Foreground="{StaticResource BrushEditorTextSecondary}"
        IsReadOnly="True"
        Padding="8"
        ScrollViewer.HorizontalScrollBarVisibility="Auto"
        ScrollViewer.VerticalScrollBarVisibility="Auto"
        SelectionBrush="{StaticResource BrushEditorAccentSelected}"
        SelectionForegroundBrush="{StaticResource BrushEditorTextOnAccent}"
        TextWrapping="NoWrap">
      <TextBox.ContextMenu>
        <ContextMenu>
          <MenuItem Header="复制选中内容" Click="OnCopySelectionClicked" />
          <MenuItem Header="复制全部日志" Click="OnCopyAllClicked" />
        </ContextMenu>
      </TextBox.ContextMenu>
    </TextBox>
  </Border>
</UserControl>
