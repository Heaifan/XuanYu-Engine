<UserControl
    x:Class="XuanYu.Engine.Editor.Windows.Panels.Inspector.InspectorPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Padding="14"
      Background="{StaticResource BrushEditorPanelBackground}"
      BorderBrush="{StaticResource BrushEditorBorder}"
      BorderThickness="0,0,0,0">
    <StackPanel Spacing="10">
      <TextBlock
          FontSize="14"
          FontWeight="SemiBold"
          Foreground="{StaticResource BrushEditorTextPrimary}"
          Text="检查器" />

      <!-- 未选择状态 -->
      <TextBlock x:Name="EmptySelectionText" Foreground="{StaticResource BrushEditorTextSecondary}" Text="未选择对象" />

      <!-- 选择详情区域（含实体信息和 Transform） -->
      <StackPanel x:Name="SelectionDetails" IsVisible="False" Spacing="10">
        <!-- 实体信息 -->
        <TextBlock Text="实体信息" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrushEditorTextMuted}" />
        <TextBlock x:Name="SelectionKindText" Foreground="{StaticResource BrushEditorTextSecondary}" />
        <TextBlock x:Name="SelectionNameText" Foreground="{StaticResource BrushEditorTextSecondary}" />
        <TextBlock x:Name="SelectionEntityIdText" Foreground="{StaticResource BrushEditorTextMuted}" FontSize="11" />
        <TextBlock x:Name="SelectionSourceText" Foreground="{StaticResource BrushEditorTextMuted}" FontSize="11" TextWrapping="Wrap" />

        <Rectangle Height="1" Fill="{StaticResource BrushEditorBorder}" Margin="0,4" />

        <!-- Transform 编辑区（仅世界实体显示） -->
        <StackPanel x:Name="TransformSection" IsVisible="False" Spacing="6">
          <TextBlock Text="Transform" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrushEditorTextMuted}" />

          <!-- 位置 -->
          <TextBlock Text="位置" FontSize="11" Foreground="{StaticResource BrushEditorTextMuted}" />
          <Grid ColumnDefinitions="Auto,8,*">
            <TextBlock Grid.Column="0" x:Name="ScrubLabelX" Text="X" Foreground="{StaticResource BrushEditorTextSecondary}"
                       VerticalAlignment="Center" Cursor="SizeWestEast" />
            <TextBox Grid.Column="2" x:Name="TransformXText" Text="0.000"
                     Foreground="{StaticResource BrushEditorTextPrimary}" Background="{StaticResource BrushEditorInputBackground}" BorderBrush="{StaticResource BrushEditorBorderSoft}" />
          </Grid>
          <Grid ColumnDefinitions="Auto,8,*">
            <TextBlock Grid.Column="0" x:Name="ScrubLabelY" Text="Y" Foreground="{StaticResource BrushEditorTextSecondary}"
                       VerticalAlignment="Center" Cursor="SizeWestEast" />
            <TextBox Grid.Column="2" x:Name="TransformYText" Text="0.000"
                     Foreground="{StaticResource BrushEditorTextPrimary}" Background="{StaticResource BrushEditorInputBackground}" BorderBrush="{StaticResource BrushEditorBorderSoft}" />
          </Grid>
          <Grid ColumnDefinitions="Auto,8,*">
            <TextBlock Grid.Column="0" x:Name="ScrubLabelZ" Text="Z" Foreground="{StaticResource BrushEditorTextSecondary}"
                       VerticalAlignment="Center" Cursor="SizeWestEast" />
            <TextBox Grid.Column="2" x:Name="TransformZText" Text="0.000"
                     Foreground="{StaticResource BrushEditorTextPrimary}" Background="{StaticResource BrushEditorInputBackground}" BorderBrush="{StaticResource BrushEditorBorderSoft}" />
          </Grid>

          <!-- 旋转 -->
          <TextBlock Text="旋转" FontSize="11" Foreground="{StaticResource BrushEditorTextMuted}" Margin="0,4,0,0" />
          <Grid ColumnDefinitions="Auto,8,*">
            <TextBlock x:Name="RotationLabelX" Text="X" Foreground="{StaticResource BrushEditorTextSecondary}"
                       VerticalAlignment="Center" Cursor="SizeWestEast" />
            <TextBox Grid.Column="2" x:Name="RotationXText" Text="0.000"
                     Foreground="{StaticResource BrushEditorTextPrimary}" Background="{StaticResource BrushEditorInputBackground}" BorderBrush="{StaticResource BrushEditorBorderSoft}" />
          </Grid>
          <Grid ColumnDefinitions="Auto,8,*">
            <TextBlock x:Name="RotationLabelY" Text="Y" Foreground="{StaticResource BrushEditorTextSecondary}"
                       VerticalAlignment="Center" Cursor="SizeWestEast" />
            <TextBox Grid.Column="2" x:Name="RotationYText" Text="0.000"
                     Foreground="{StaticResource BrushEditorTextPrimary}" Background="{StaticResource BrushEditorInputBackground}" BorderBrush="{StaticResource BrushEditorBorderSoft}" />
          </Grid>
          <Grid ColumnDefinitions="Auto,8,*">
            <TextBlock x:Name="RotationLabelZ" Text="Z" Foreground="{StaticResource BrushEditorTextSecondary}"
                       VerticalAlignment="Center" Cursor="SizeWestEast" />
            <TextBox Grid.Column="2" x:Name="RotationZText" Text="0.000"
                     Foreground="{StaticResource BrushEditorTextPrimary}" Background="{StaticResource BrushEditorInputBackground}" BorderBrush="{StaticResource BrushEditorBorderSoft}" />
          </Grid>

          <!-- 缩放 -->
          <TextBlock Text="缩放" FontSize="11" Foreground="{StaticResource BrushEditorTextMuted}" Margin="0,4,0,0" />
          <Grid ColumnDefinitions="Auto,8,*">
            <TextBlock x:Name="ScaleLabelX" Text="X" Foreground="{StaticResource BrushEditorTextSecondary}"
                       VerticalAlignment="Center" Cursor="SizeWestEast" />
            <TextBox Grid.Column="2" x:Name="ScaleXText" Text="1.000"
                     Foreground="{StaticResource BrushEditorTextPrimary}" Background="{StaticResource BrushEditorInputBackground}" BorderBrush="{StaticResource BrushEditorBorderSoft}" />
          </Grid>
          <Grid ColumnDefinitions="Auto,8,*">
            <TextBlock x:Name="ScaleLabelY" Text="Y" Foreground="{StaticResource BrushEditorTextSecondary}"
                       VerticalAlignment="Center" Cursor="SizeWestEast" />
            <TextBox Grid.Column="2" x:Name="ScaleYText" Text="1.000"
                     Foreground="{StaticResource BrushEditorTextPrimary}" Background="{StaticResource BrushEditorInputBackground}" BorderBrush="{StaticResource BrushEditorBorderSoft}" />
          </Grid>
          <Grid ColumnDefinitions="Auto,8,*">
            <TextBlock x:Name="ScaleLabelZ" Text="Z" Foreground="{StaticResource BrushEditorTextSecondary}"
                       VerticalAlignment="Center" Cursor="SizeWestEast" />
            <TextBox Grid.Column="2" x:Name="ScaleZText" Text="1.000"
                     Foreground="{StaticResource BrushEditorTextPrimary}" Background="{StaticResource BrushEditorInputBackground}" BorderBrush="{StaticResource BrushEditorBorderSoft}" />
          </Grid>

          <!-- 错误信息 -->
          <TextBlock x:Name="TransformErrorText" Foreground="{StaticResource BrushEditorError}" FontSize="11"
                     TextWrapping="Wrap" IsVisible="False" />

          <!-- 按钮行 -->
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Button x:Name="ApplyButton" Content="应用坐标"
                    IsEnabled="False"
                    Foreground="{StaticResource BrushEditorTextOnAccent}" Background="{StaticResource BrushEditorAccentSelected}"
                    BorderThickness="0" Padding="10,4" />
            <Button x:Name="ResetButton" Content="重置"
                    Foreground="{StaticResource BrushEditorTextPrimary}" Background="{StaticResource BrushEditorButtonBackground}"
                    BorderThickness="0" Padding="10,4" />
            <Button x:Name="GroundPlaceButton" Content="在地面放置"
                    IsEnabled="False"
                    Foreground="{StaticResource BrushEditorTextOnAccent}" Background="{StaticResource BrushEditorSuccess}"
                    BorderThickness="0" Padding="10,4" />
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
