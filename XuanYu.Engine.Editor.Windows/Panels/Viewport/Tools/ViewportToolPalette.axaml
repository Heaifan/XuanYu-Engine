<UserControl
    x:Class="XuanYu.Engine.Editor.Windows.Panels.Viewport.Tools.ViewportToolPalette"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{StaticResource BrushEditorPanelBackground}" Padding="6">
    <StackPanel Spacing="4">
      <Button x:Name="SelectButton" Content="选择" Width="32" Height="32"
              Background="{StaticResource BrushEditorButtonBackground}" Foreground="{StaticResource BrushEditorTextSecondary}" BorderThickness="1" BorderBrush="{StaticResource BrushEditorBorderSoft}"
              Padding="0" FontSize="10" Click="OnSelectClicked" />
      <Button x:Name="MoveButton" Content="移动" Width="32" Height="32"
              Background="{StaticResource BrushEditorButtonBackground}" Foreground="{StaticResource BrushEditorTextSecondary}" BorderThickness="1" BorderBrush="{StaticResource BrushEditorBorderSoft}"
              Padding="0" FontSize="10" Click="OnMoveClicked" />
    </StackPanel>
  </Border>
</UserControl>
