<UserControl
    x:Class="XuanYu.Engine.Editor.Windows.Panels.Viewport.VulkanViewportHostPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:nativeHost="clr-namespace:XuanYu.Engine.Editor.Windows.Panels.Viewport.NativeHost">
  <Border
      Margin="0"
      Background="{StaticResource BrushEditorViewportFrameBackground}"
      BorderBrush="{StaticResource BrushEditorBorder}"
      BorderThickness="0,0,1,1"
      Padding="0"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch">
    <Grid RowDefinitions="Auto,*,Auto" Margin="0">
      <TextBlock
          Grid.Row="0"
          Margin="14,8,14,4"
          FontSize="14"
          FontWeight="SemiBold"
          Foreground="{StaticResource BrushEditorTextPrimary}"
          Text="Vulkan 3D 战场视口" />
      <Border
          Grid.Row="1"
          Margin="0"
          MinHeight="360"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          Background="{StaticResource BrushEditorViewportCanvasBackground}"
          BorderBrush="{StaticResource BrushEditorBorderSoft}"
          BorderThickness="0">
        <nativeHost:WindowsVulkanViewportHostControl
            x:Name="NativeHostControl"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" />
      </Border>
      <TextBlock
          Grid.Row="2"
          x:Name="ClearStatusText"
          Margin="20,6,20,10"
          Foreground="{StaticResource BrushEditorTextMuted}"
          FontSize="12"
          Text="Vulkan 清屏状态：等待初始化..." />
    </Grid>
  </Border>
</UserControl>
