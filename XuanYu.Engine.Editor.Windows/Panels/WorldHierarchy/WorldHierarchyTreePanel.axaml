<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hierarchy="clr-namespace:FluidWarfare.Editor.Windows.Panels.HierarchyVisual"
             x:Class="FluidWarfare.Editor.Windows.Panels.WorldHierarchy.WorldHierarchyTreePanel"
             UseLayoutRounding="True">
  <UserControl.Styles>
    <Style Selector="ListBox.hierarchyList">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBox.hierarchyList ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="ListBox.hierarchyList ListBoxItem:pointerover">
      <Setter Property="Background" Value="#24313C" />
    </Style>

    <Style Selector="ListBox.hierarchyList ListBoxItem:selected">
      <Setter Property="Background" Value="#1769AA" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="ListBox.hierarchyList ListBoxItem:selected TextBlock.hierarchySecondary">
      <Setter Property="Foreground" Value="#D9E8F5" />
    </Style>
  </UserControl.Styles>

  <ListBox Name="HierarchyList"
           Classes="hierarchyList"
           SelectionMode="Single">
    <ListBox.ItemTemplate>
      <DataTemplate>
        <hierarchy:HierarchyNodeRow />
      </DataTemplate>
    </ListBox.ItemTemplate>
  </ListBox>
</UserControl>
