<UserControl
    x:Class="XuanYu.Engine.Editor.Windows.Panels.Status.StatusBarPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Padding="14,0"
      Background="{StaticResource BrushEditorStatusBarBackground}"
      BorderBrush="{StaticResource BrushEditorBorder}"
      BorderThickness="0,1,0,0">
    <StackPanel
        VerticalAlignment="Center"
        Orientation="Horizontal"
        Spacing="18">
      <TextBlock Foreground="{StaticResource BrushEditorTextPrimary}" Text="状态：就绪" />
      <TextBlock Foreground="{StaticResource BrushEditorTextMuted}" Text="|" />
      <TextBlock Foreground="{StaticResource BrushEditorTextPrimary}" Text="阶段：GUI 原型" />
      <TextBlock Foreground="{StaticResource BrushEditorTextMuted}" Text="|" />
      <TextBlock Foreground="{StaticResource BrushEditorTextPrimary}" Text="Core：已加载" />
      <TextBlock Foreground="{StaticResource BrushEditorTextMuted}" Text="|" />
      <TextBlock x:Name="VulkanStatusText" Foreground="{StaticResource BrushEditorTextPrimary}" Text="Vulkan：未接入" />
      <TextBlock Foreground="{StaticResource BrushEditorTextMuted}" Text="|" />
      <TextBlock x:Name="CurrentSelectionText" Foreground="{StaticResource BrushEditorTextPrimary}" Text="当前选择：无" />
      <TextBlock Foreground="{StaticResource BrushEditorTextMuted}" Text="|" />
      <TextBlock x:Name="GroundCoordText" Foreground="{StaticResource BrushEditorTextMuted}" Text="地面坐标：无" />
      <TextBlock Foreground="{StaticResource BrushEditorTextMuted}" Text="|" />
      <TextBlock x:Name="DirtyStateText" Foreground="{StaticResource BrushEditorTextPrimary}" Text="场景：未修改" />
    </StackPanel>
  </Border>
</UserControl>
