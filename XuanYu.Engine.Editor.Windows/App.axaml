<Application
    x:Class="XuanYu.Engine.Editor.Windows.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedThemeVariant="Dark">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/UI/Theme/EditorThemeColors.axaml" />
        <ResourceInclude Source="/UI/Theme/EditorThemeBrushes.axaml" />
        <ResourceInclude Source="/UI/Icons/CommandIconData.axaml" />
        <ResourceInclude Source="/UI/Icons/ToolIconData.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="/UI/Styles/TopAreaButtonStyles.axaml" />
  </Application.Styles>
</Application>
