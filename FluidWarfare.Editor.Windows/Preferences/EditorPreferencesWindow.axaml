<Window
    x:Class="FluidWarfare.Editor.Windows.Preferences.EditorPreferencesWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="偏好设置"
    Width="700"
    Height="500"
    MinWidth="600"
    MinHeight="400"
    WindowStartupLocation="CenterOwner"
    Background="#202327"
    Foreground="#E0E0E0">
  <Grid ColumnDefinitions="180,*" Margin="0">
    <Border Grid.Column="0" Background="#2A2F36" BorderBrush="#414852" BorderThickness="0,0,1,0">
      <StackPanel Margin="8">
        <TextBlock Text="设置" FontWeight="Bold" Foreground="#888" Margin="8,12,8,8" FontSize="13" />
        <ListBox x:Name="CategoryList" Background="Transparent" BorderThickness="0" SelectedIndex="0">
          <ListBoxItem IsSelected="True" Background="Transparent">
            <TextBlock Text="键位" Foreground="#CCC" Padding="8,6" />
          </ListBoxItem>
        </ListBox>
      </StackPanel>
    </Border>
    <ScrollViewer Grid.Column="1" Margin="16">
      <StackPanel x:Name="ContentPanel" Spacing="8">
        <TextBlock Text="键位设置" FontSize="18" FontWeight="Bold" Foreground="#FFF" />
        <TextBlock Text="自定义编辑器的键盘和鼠标快捷键。" Foreground="#AAA" TextWrapping="Wrap" Margin="0,0,0,12" />

        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBox x:Name="SearchBox" Watermark="搜索动作或按键……" Width="300" Height="30" />
          <TextBlock Text="预设：" VerticalAlignment="Center" Foreground="#AAA" />
          <ComboBox x:Name="PresetCombo" SelectedIndex="0" Width="150">
            <ComboBoxItem>Blender 默认</ComboBoxItem>
          </ComboBox>
        </StackPanel>

        <StackPanel x:Name="BindingsContainer" Spacing="2">
          <!-- 绑定行由代码生成 -->
        </StackPanel>

        <Button Content="恢复全部 Blender 默认" Margin="0,16,0,0" Background="#353B44" Foreground="#CCC" BorderThickness="1" BorderBrush="#555" Padding="12,6" Click="OnRestoreAllClicked" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
