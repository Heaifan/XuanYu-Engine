<UserControl
    x:Class="FluidWarfare.Editor.Windows.Panels.Viewport.ViewportPlaceholderPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Margin="0"
      Background="#15191E"
      BorderBrush="#48515C"
      BorderThickness="0,0,1,0"
      PointerPressed="HandleViewportPointerPressed">
    <Grid RowDefinitions="Auto,*" Margin="20">
      <TextBlock
          Grid.Row="0"
          FontSize="18"
          FontWeight="SemiBold"
          Foreground="#F0F4F8"
          Text="3D 视口" />

      <!-- 默认状态：未选择 World 实体 -->
      <StackPanel
          x:Name="DefaultContent"
          Grid.Row="1"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Spacing="10">
        <TextBlock
            HorizontalAlignment="Center"
            FontSize="22"
            Foreground="#F0F4F8"
            Text="Vulkan 渲染器尚未接入" />
        <TextBlock
            HorizontalAlignment="Center"
            Foreground="#AEB7C2"
            Text="后续将在此显示 3D 战场" />
        <TextBlock
            HorizontalAlignment="Center"
            Foreground="#7F8B98"
            Text="点击此区域可聚焦视口占位区" />
      </StackPanel>

      <!-- 无实体状态：World 为空 -->
      <StackPanel
          x:Name="EmptyWorldContent"
          Grid.Row="1"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Spacing="10"
          IsVisible="False">
        <TextBlock
            HorizontalAlignment="Center"
            FontSize="22"
            Foreground="#F0F4F8"
            Text="3D 视口" />
        <TextBlock
            HorizontalAlignment="Center"
            Foreground="#AEB7C2"
            Text="当前 World 没有实体" />
        <TextBlock
            HorizontalAlignment="Center"
            Foreground="#7F8B98"
            Text="请检查项目内容目录中是否存在单位模板文件。" />
      </StackPanel>

      <!-- 实体摘要状态：显示当前选中实体 -->
      <StackPanel
          x:Name="EntitySummaryContent"
          Grid.Row="1"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Spacing="8"
          IsVisible="False">
        <TextBlock
            x:Name="EntityTypeLabel"
            HorizontalAlignment="Center"
            FontSize="20"
            Foreground="#F0F4F8" />
        <TextBlock
            x:Name="EntityNameText"
            HorizontalAlignment="Center"
            FontSize="28"
            FontWeight="SemiBold"
            Foreground="#58A6FF" />
        <Separator Margin="40,4" />
        <StackPanel Spacing="4" HorizontalAlignment="Center">
          <TextBlock Foreground="#AEB7C2" HorizontalAlignment="Center" Text="EntityId" />
          <TextBlock x:Name="EntityIdText" Foreground="#F0F4F8" HorizontalAlignment="Center" />
        </StackPanel>
        <StackPanel Spacing="4" HorizontalAlignment="Center">
          <TextBlock Foreground="#AEB7C2" HorizontalAlignment="Center" Text="来源" />
          <TextBlock x:Name="EntitySourceText" Foreground="#F0F4F8" HorizontalAlignment="Center" />
        </StackPanel>
        <StackPanel Spacing="4" HorizontalAlignment="Center">
          <TextBlock Foreground="#AEB7C2" HorizontalAlignment="Center" Text="位置" />
          <TextBlock x:Name="EntityPositionText" Foreground="#F0F4F8" HorizontalAlignment="Center" />
        </StackPanel>
        <StackPanel Spacing="4" HorizontalAlignment="Center">
          <TextBlock Foreground="#AEB7C2" HorizontalAlignment="Center" Text="渲染对象" />
          <TextBlock x:Name="EntityVisualKindText" Foreground="#58A6FF" HorizontalAlignment="Center" />
        </StackPanel>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
