<UserControl
    x:Class="FluidWarfare.Editor.Windows.Panels.Viewport.ViewportPlaceholderPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Margin="0"
      Background="#15191E"
      BorderBrush="#48515C"
      BorderThickness="0,0,1,0"
      PointerPressed="HandleViewportPointerPressed">
    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
      <TextBlock
          Grid.Row="0"
          FontSize="18"
          FontWeight="SemiBold"
          Foreground="#F0F4F8"
          Text="3D 视口" />

      <!-- 主体内容 — 三状态面板 -->
      <StackPanel
          x:Name="DefaultContent"
          Grid.Row="1"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Spacing="10">
        <TextBlock
            HorizontalAlignment="Center"
            FontSize="22"
            Foreground="#F0F4F8"
            Text="Vulkan 渲染器尚未接入" />
        <TextBlock
            HorizontalAlignment="Center"
            Foreground="#AEB7C2"
            Text="后续将在此显示 3D 战场" />
        <TextBlock
            HorizontalAlignment="Center"
            Foreground="#7F8B98"
            Text="点击此区域可聚焦视口占位区" />
      </StackPanel>

      <StackPanel
          x:Name="EmptyWorldContent"
          Grid.Row="1"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Spacing="10"
          IsVisible="False">
        <TextBlock
            HorizontalAlignment="Center"
            FontSize="22"
            Foreground="#F0F4F8"
            Text="3D 视口" />
        <TextBlock
            HorizontalAlignment="Center"
            Foreground="#AEB7C2"
            Text="当前 World 没有实体" />
        <TextBlock
            HorizontalAlignment="Center"
            Foreground="#7F8B98"
            Text="请检查项目内容目录中是否存在单位模板文件。" />
      </StackPanel>

      <StackPanel
          x:Name="EntitySummaryContent"
          Grid.Row="1"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Spacing="8"
          IsVisible="False">
        <TextBlock
            x:Name="EntityTypeLabel"
            HorizontalAlignment="Center"
            FontSize="20"
            Foreground="#F0F4F8" />
        <TextBlock
            x:Name="EntityNameText"
            HorizontalAlignment="Center"
            FontSize="28"
            FontWeight="SemiBold"
            Foreground="#58A6FF" />
        <Separator Margin="40,4" />
        <StackPanel Spacing="4" HorizontalAlignment="Center">
          <TextBlock Foreground="#AEB7C2" HorizontalAlignment="Center" Text="EntityId" />
          <TextBlock x:Name="EntityIdText" Foreground="#F0F4F8" HorizontalAlignment="Center" />
        </StackPanel>
        <StackPanel Spacing="4" HorizontalAlignment="Center">
          <TextBlock Foreground="#AEB7C2" HorizontalAlignment="Center" Text="来源" />
          <TextBlock x:Name="EntitySourceText" Foreground="#F0F4F8" HorizontalAlignment="Center" />
        </StackPanel>
        <StackPanel Spacing="4" HorizontalAlignment="Center">
          <TextBlock Foreground="#AEB7C2" HorizontalAlignment="Center" Text="位置" />
          <TextBlock x:Name="EntityPositionText" Foreground="#F0F4F8" HorizontalAlignment="Center" />
        </StackPanel>
        <StackPanel Spacing="4" HorizontalAlignment="Center">
          <TextBlock Foreground="#AEB7C2" HorizontalAlignment="Center" Text="渲染对象" />
          <TextBlock x:Name="EntityVisualKindText" Foreground="#58A6FF" HorizontalAlignment="Center" />
        </StackPanel>
      </StackPanel>

      <!-- 底部：RenderScene 调试对象列表 -->
      <Border
          Grid.Row="2"
          Background="#1A1F26"
          BorderBrush="#48515C"
          BorderThickness="0,1,0,0"
          Padding="16,10">
        <StackPanel Spacing="6">
          <TextBlock
              FontSize="14"
              FontWeight="SemiBold"
              Foreground="#F0F4F8"
              Text="RenderScene 调试对象" />
          <TextBlock
              x:Name="DebugListEmptyText"
              Foreground="#8B949E"
              IsVisible="False"
              Text="暂无渲染对象" />
          <StackPanel x:Name="DebugListPanel" IsVisible="False" Spacing="4" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</UserControl>
