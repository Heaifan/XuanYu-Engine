<UserControl
    x:Class="FluidWarfare.Editor.Windows.Panels.WorldEntities.WorldEntityListPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Margin="0"
      Padding="14"
      Background="#262B33"
      BorderBrush="#48515C"
      BorderThickness="0,0,1,0">
    <StackPanel Spacing="10">
      <TextBlock
          FontSize="14"
          FontWeight="SemiBold"
          Foreground="#F0F4F8"
          Text="World 实体" />
      <TextBlock
          x:Name="WorldEntityEmptyText"
          Foreground="#8B949E"
          IsVisible="True"
          Text="暂无 World 实体" />
      <StackPanel x:Name="WorldEntityList" Spacing="8" IsVisible="False" />
    </StackPanel>
  </Border>
</UserControl>
