<UserControl
    x:Class="FluidWarfare.Editor.Windows.Panels.Project.ProjectPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Margin="0"
      Padding="18"
      Background="#262B33"
      BorderBrush="#48515C"
      BorderThickness="0,0,1,0">
    <StackPanel Spacing="14">
      <TextBlock
          FontSize="18"
          FontWeight="SemiBold"
          Foreground="#F0F4F8"
          Text="项目" />
      <TextBlock Foreground="#C9D1D9" Text="当前未打开项目" />
      <Separator />
      <TextBlock Foreground="#E6EDF3" Text="场景" />
      <TextBlock Foreground="#E6EDF3" Text="单位" />
      <TextBlock Foreground="#E6EDF3" Text="资源" />
      <TextBlock Foreground="#E6EDF3" Text="配置" />
    </StackPanel>
  </Border>
</UserControl>
