<UserControl
    x:Class="FluidWarfare.Editor.Windows.Panels.Project.ProjectPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Margin="0"
      Padding="14"
      Background="#262B33"
      BorderBrush="#48515C"
      BorderThickness="0,0,1,0">
    <StackPanel Spacing="10">
      <TextBlock
          FontSize="14"
          FontWeight="SemiBold"
          Foreground="#F0F4F8"
          Text="项目" />
      <TextBlock
          x:Name="ProjectNameText"
          Foreground="#C9D1D9"
          Text="当前未打开项目" />
      <Separator />
      <StackPanel x:Name="ProjectItemList" Spacing="8" />
    </StackPanel>
  </Border>
</UserControl>
