<UserControl
    x:Class="FluidWarfare.Editor.Windows.Panels.Logging.LogPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Padding="16"
      Background="#1C2025"
      BorderBrush="#414852"
      BorderThickness="0,1,0,0">
    <Grid RowDefinitions="Auto,*">
      <TextBlock
          Grid.Row="0"
          Margin="0,0,0,10"
          FontSize="18"
          FontWeight="SemiBold"
          Text="日志" />
      <ItemsControl Grid.Row="1" x:Name="LogList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock
                Margin="0,0,0,6"
                FontFamily="Consolas, Microsoft YaHei UI"
                Foreground="#DCE3EA"
                Text="{Binding}" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Grid>
  </Border>
</UserControl>
