<UserControl
    x:Class="FluidWarfare.Editor.Windows.Panels.Logging.LogPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Padding="18,14"
      Background="#1B2026"
      BorderBrush="#48515C"
      BorderThickness="0,1,0,0">
    <Grid RowDefinitions="Auto,*">
      <TextBlock
          Grid.Row="0"
          Margin="0,0,0,10"
          FontSize="18"
          FontWeight="SemiBold"
          Foreground="#F0F4F8"
          Text="日志" />
      <TextBox
          Grid.Row="1"
          x:Name="LogTextBox"
          AcceptsReturn="True"
          Background="#11161C"
          BorderBrush="#303944"
          BorderThickness="1"
          CaretBrush="#F0F4F8"
          FontFamily="Consolas, Microsoft YaHei UI"
          FontSize="12"
          Foreground="#DCE3EA"
          IsReadOnly="True"
          Padding="8"
          ScrollViewer.HorizontalScrollBarVisibility="Auto"
          ScrollViewer.VerticalScrollBarVisibility="Auto"
          TextWrapping="NoWrap" />
    </Grid>
  </Border>
</UserControl>
