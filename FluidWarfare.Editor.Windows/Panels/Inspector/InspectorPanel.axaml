<UserControl
    x:Class="FluidWarfare.Editor.Windows.Panels.Inspector.InspectorPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Padding="14"
      Background="#262B33"
      BorderBrush="#48515C"
      BorderThickness="0,0,0,0">
    <StackPanel Spacing="10">
      <TextBlock
          FontSize="14"
          FontWeight="SemiBold"
          Foreground="#F0F4F8"
          Text="检查器" />
      <TextBlock x:Name="EmptySelectionText" Foreground="#C9D1D9" Text="未选择对象" />
      <StackPanel x:Name="SelectionDetails" IsVisible="False" Spacing="10">
        <TextBlock x:Name="SelectionKindText" Foreground="#C9D1D9" />
        <TextBlock x:Name="SelectionNameText" Foreground="#C9D1D9" />
        <TextBlock
            x:Name="SelectionDescriptionText"
            Foreground="#C9D1D9"
            TextWrapping="Wrap" />
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
