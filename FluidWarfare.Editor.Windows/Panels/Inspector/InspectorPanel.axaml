<UserControl
    x:Class="FluidWarfare.Editor.Windows.Panels.Inspector.InspectorPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border
      Padding="18"
      Background="#262B33"
      BorderBrush="#48515C"
      BorderThickness="0,0,0,0">
    <StackPanel Spacing="14">
      <TextBlock
          FontSize="18"
          FontWeight="SemiBold"
          Foreground="#F0F4F8"
          Text="检查器" />
      <TextBlock Foreground="#C9D1D9" Text="未选择对象" />
    </StackPanel>
  </Border>
</UserControl>
