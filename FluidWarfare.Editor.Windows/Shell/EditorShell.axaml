<UserControl
    x:Class="FluidWarfare.Editor.Windows.Shell.EditorShell"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:inspector="clr-namespace:FluidWarfare.Editor.Windows.Panels.Inspector"
    xmlns:logging="clr-namespace:FluidWarfare.Editor.Windows.Panels.Logging"
    xmlns:project="clr-namespace:FluidWarfare.Editor.Windows.Panels.Project"
    xmlns:status="clr-namespace:FluidWarfare.Editor.Windows.Panels.Status"
    xmlns:viewport="clr-namespace:FluidWarfare.Editor.Windows.Panels.Viewport"
    xmlns:worldEntities="clr-namespace:FluidWarfare.Editor.Windows.Panels.WorldEntities">
  <Grid Background="#202327" RowDefinitions="44,*,220,28">
    <Border
        Grid.Row="0"
        Background="#2A2F36"
        BorderBrush="#414852"
        BorderThickness="0,0,0,1">
      <StackPanel
          Margin="18,0"
          VerticalAlignment="Center"
          Orientation="Horizontal"
          Spacing="24">
        <Button Padding="8,4" Background="Transparent" BorderThickness="0" Click="HandleFileMenuClicked">文件</Button>
        <Button Padding="8,4" Background="Transparent" BorderThickness="0" Click="HandleEditMenuClicked">编辑</Button>
        <Button Padding="8,4" Background="Transparent" BorderThickness="0" Click="HandleViewMenuClicked">视图</Button>
        <Button Padding="8,4" Background="Transparent" BorderThickness="0" Click="HandleRunMenuClicked">运行</Button>
        <Button Padding="8,4" Background="Transparent" BorderThickness="0" Click="HandleExportMenuClicked">导出</Button>
        <Button Padding="8,4" Background="Transparent" BorderThickness="0" Click="HandleHelpMenuClicked">帮助</Button>
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="260,*,300">
      <Grid Grid.Column="0" RowDefinitions="2*,*">
        <project:ProjectPanel Grid.Row="0" x:Name="ProjectPanel" />
        <worldEntities:WorldEntityListPanel Grid.Row="1" x:Name="WorldEntityListPanel" />
      </Grid>
      <Grid Grid.Column="1" RowDefinitions="Auto,*">
        <viewport:VulkanViewportHostPanel Grid.Row="0" x:Name="VulkanViewportHostPanel" />
        <viewport:ViewportPlaceholderPanel Grid.Row="1" x:Name="ViewportPlaceholderPanel" />
      </Grid>
      <inspector:InspectorPanel Grid.Column="2" x:Name="InspectorPanel" />
    </Grid>

    <logging:LogPanel Grid.Row="2" x:Name="EditorLogPanel" />
    <status:StatusBarPanel Grid.Row="3" x:Name="EditorStatusBarPanel" />
  </Grid>
</UserControl>
